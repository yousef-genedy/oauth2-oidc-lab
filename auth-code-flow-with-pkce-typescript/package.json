{
  "name": "keycloak-oauth2-oidc-poc",
  "version": "1.0.0",
  "description": "Minimal OAuth 2.0 + OpenID Connect Authorization Code + PKCE demo with Keycloak",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "keywords": [
    "oauth2",
    "oidc",
    "pkce",
    "keycloak",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  }
}

